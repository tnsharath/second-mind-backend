# Required for LLM-backed replies (chat / briefing / summary work without it,
# falling back to deterministic templates)
OPENAI_API_KEY=sk-your-key-here

# Optional
OPENAI_MODEL=gpt-4o-mini
AURA_SYSTEM_PROMPT=You are AURA, a persistent AI companion...

# Database (SQLModel/SQLAlchemy URL). Defaults to sqlite:///./aura.db
AURA_DB_URL=sqlite:///./aura.db
